# SOC Bot — Environment Variables
# copy ไฟล์นี้เป็น .env แล้วแก้ค่าให้ถูกต้อง

# ── Wazuh ──────────────────────────────────────────────────────────────────────
WAZUH_API_URL=https://192.168.x.x:55000
WAZUH_USER=wazuh
WAZUH_PASSWORD=

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120

# ── TheHive ────────────────────────────────────────────────────────────────────
THEHIVE_URL=http://localhost:9000
THEHIVE_API_KEY=
THEHIVE_TLP=2
THEHIVE_PAP=2

# ── LINE Notify ────────────────────────────────────────────────────────────────
LINE_NOTIFY_TOKEN=

# ── SOC Dashboard ──────────────────────────────────────────────────────────────
DJANGO_DASHBOARD_URL=http://localhost:8500
DASHBOARD_URL=http://localhost:8500
DASHBOARD_API_TOKEN=

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── General ────────────────────────────────────────────────────────────────────
POLL_INTERVAL=60
LOG_LEVEL=INFO
