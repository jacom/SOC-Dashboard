# =============================================================================
# SOC Dashboard — Environment Configuration
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าทุกบรรทัดที่มี <...>
#   cp .env.example .env
# =============================================================================

# ── Django Core ───────────────────────────────────────────────────────────────
# สร้าง SECRET_KEY ด้วย: python3 -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=<your-secret-key-here>

DEBUG=False

# IP หรือ domain ของเซิร์ฟเวอร์ (คั่นด้วยจุลภาค)
ALLOWED_HOSTS=localhost,127.0.0.1,<your-server-ip>

# สำหรับ reverse proxy / nginx (ใส่ URL เต็มที่ผู้ใช้เข้าถึง)
CSRF_TRUSTED_ORIGINS=http://<your-server-ip>:8500

# ── Database (Docker จะสร้างให้อัตโนมัติ) ────────────────────────────────────
DB_NAME=soc_db
DB_USER=soc_user
# สร้างรหัสผ่านด้วย: openssl rand -hex 16
DB_PASSWORD=<strong-db-password>

# ── Redis ─────────────────────────────────────────────────────────────────────
# Docker: ไม่ต้องแก้ (ใช้ service name 'redis')
# Non-Docker: redis://127.0.0.1:6379/1
REDIS_URL=redis://127.0.0.1:6379/1

# ── Dashboard Public URL ──────────────────────────────────────────────────────
DJANGO_DASHBOARD_URL=http://<your-server-ip>:8500

# ── Port (Docker only) ────────────────────────────────────────────────────────
DASHBOARD_PORT=8500

# ── SOC Bot API Token ─────────────────────────────────────────────────────────
# สร้างหลังจาก createsuperuser แล้วที่ /admin/ → Auth Token
SOC_BOT_API_TOKEN=<api-token-from-admin>

# ── License ───────────────────────────────────────────────────────────────────
# สร้างด้วย: python3 -c "import secrets; print(secrets.token_hex(32))"
# ค่านี้ต้องตรงกับที่ vendor ใช้ sign license key — อย่าเปลี่ยนหลัง deploy
LICENSE_VENDOR_SECRET=<your-vendor-secret-64-chars>
LICENSE_GRACE_DAYS=30

# ── Wazuh Indexer (OpenSearch) ────────────────────────────────────────────────
WAZUH_INDEXER_URL=https://<wazuh-server-ip>:9200
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=<wazuh-indexer-password>
WAZUH_VULN_INDEX=wazuh-states-vulnerabilities-wazuh-server
